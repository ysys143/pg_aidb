# pg_aidb environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ------------------------------------------------------------
# OpenAI API
# ------------------------------------------------------------
# Create a dedicated test project at platform.openai.com
# and set a monthly spending limit (e.g. $5) for safety.
OPENAI_API_KEY=sk-proj-...your-key-here...

# Model selection — provider-agnostic names.
# The service reads these and passes them to the appropriate provider SDK.
EMBED_MODEL=text-embedding-3-small
LLM_MODEL=gpt-5.4-mini

# LLM provider — openai (default, also covers OpenAI-compat) | anthropic
# Embeddings always use OpenAI-compat shape (no Anthropic embed API).
LLM_PROVIDER=openai

# Anthropic — only used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# Vector dimension — must match EMBED_MODEL's output width.
# text-embedding-3-small  → 1536  (default, cheap)
# text-embedding-3-large  → 3072
# gemini-embedding-001    → 768 / 1536 / 3072 (configurable)
# Changing this requires dropping ai.chunks (data is incompatible).
EMBED_DIMENSIONS=1536

# ------------------------------------------------------------
# Mock override (leave empty for real OpenAI)
# Set to http://mock:8080/v1/ to run against the mock server.
# ------------------------------------------------------------
OPENAI_BASE_URL=
