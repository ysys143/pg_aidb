-- ai.search must return at least one chunk
SELECT COUNT(*) > 0 AS search_returns_results
FROM ai.search('What is PostgreSQL?', 'mock-rag', 5);
ERROR:  ai.search: http status: HTTP status server error (500 Internal Server Error) for url (http://rag:8002/search)
-- ai.ask must return a non-null answer
SELECT ai.ask('What is PostgreSQL?', 'mock-rag') IS NOT NULL AS ask_returns_answer;
ERROR:  ai.ask: http status: HTTP status server error (500 Internal Server Error) for url (http://rag:8002/ask)
-- Cleanup (cascade from documents removes chunks)
DELETE FROM ai.documents WHERE collection = 'mock-test-col';
ERROR:  relation "ai.documents" does not exist
