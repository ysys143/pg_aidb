                    ^
DELETE FROM ai.pipelines WHERE name = 'mock-rag';
DELETE FROM ai.results WHERE data->>'op' = 'ingest' AND data->>'source' = 'mock-doc.txt';
DROP EXTENSION pg_aidb CASCADE;
